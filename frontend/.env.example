# Copy to .env.local (gitignored by Vite's default .gitignore).
# Base URL of the FastAPI backend (src/api/main.py). Defaults to
# http://localhost:8000 in src/api/client.ts if unset. Vite inlines
# this at build time, not read at runtime - rebuild after changing it.
#
# In deploy/docker-compose.prod.yml this is deliberately left empty
# (see deploy/Dockerfile.frontend's VITE_API_BASE_URL build arg): nginx
# serves the built frontend and reverse-proxies /api/ to the backend
# from the same origin, so relative URLs (no host/port at all) are
# correct there and CORS never enters into it.
VITE_API_BASE_URL=http://localhost:8000
