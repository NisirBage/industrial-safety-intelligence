# Template for the .env file consumed by src/config/settings.py and by
# deploy/docker-compose.yml. Copy to `.env`; `.env` itself is
# gitignored and must never be committed.

APP_NAME=industrial-safety-intelligence

# Consumed directly by deploy/docker-compose.yml to configure the db
# service. Not yet read by the app itself - that starts in M1.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=isip
