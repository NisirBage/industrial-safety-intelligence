# Template for the .env file consumed by src/config/settings.py and by
# deploy/docker-compose.yml. Copy to `.env`; `.env` itself is
# gitignored and must never be committed.

APP_NAME=industrial-safety-intelligence

# Consumed directly by deploy/docker-compose.yml to configure the db
# service.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=isip

# Read by src/config/settings.py. Host-relative default works when
# running the backend directly; override to db:5432 when running
# inside docker compose, since containers cannot reach each other via
# localhost.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/isip
