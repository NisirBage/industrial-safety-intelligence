# Template for the .env file consumed by src/config/settings.py and by
# deploy/docker-compose.yml. Copy to `.env`; `.env` itself is
# gitignored and must never be committed.

APP_NAME=industrial-safety-intelligence

# Consumed directly by deploy/docker-compose.yml to configure the db
# service.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=isip

# Read by src/config/settings.py. Host-relative default works when
# running the backend directly; override to db:5432 when running
# inside docker compose, since containers cannot reach each other via
# localhost.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/isip

# Read by src/config/settings.py. Browser origins allowed to call this
# API cross-origin (M8's dashboard dev server, by default). Must be a
# JSON array of full origins (scheme + host + port), never "*" - a
# wildcard would let any website read a signed-in user's responses.
# Not needed at all in the deploy/docker-compose.prod.yml topology,
# since nginx there serves the frontend and reverse-proxies /api/ from
# the same origin, so the browser never makes a cross-origin request.
CORS_ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:5174","http://127.0.0.1:5173","http://127.0.0.1:5174","http://localhost:5180"]
